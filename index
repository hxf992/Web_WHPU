            '4': {
                title: '自驱动传感: 摩擦纳米发电机',
                content: '<p><strong>研究内容：</strong> 设计基于静电纺丝尼龙/聚偏氟乙烯复合纳米纤维的织物摩擦纳米发电机。不仅可以收集人体运动的机械能(输出功率密度达到120 mW/m²)，还可作为自驱动传感器监测手指弯曲、步态等。构建了无线关节运动监测系统。</p><p><strong>特色：</strong> 透气、柔性、可水洗，结合能量管理电路可实现蓝牙传感节点自驱动。</p>'
            }
        };

        // 给所有查看详情按钮绑定点击事件 (科研卡片)
        const detailButtons = document.querySelectorAll('.btn-detail');
        detailButtons.forEach((btn, index) => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                // 获取所在卡片对应项目编号: 通过data-project或者父级
                const card = this.closest('.news-card');
                // 更稳妥：按钮无data-project，但可以从父级查找自定义，或者用索引; 我们设置按钮的data-project属性 (简化)
                // 为方便，按钮上手动添加自定义属性? 上面html未加data-project, 所以采用映射: 取索引或找父级数据。
                // 改进：根据父级索引 (0,1,2,3) 映射
                const allCards = document.querySelectorAll('.news-card');
                let projectId = null;
                allCards.forEach((c, idx) => {
                    if (c === card) {
                        projectId = (idx + 1).toString();  // 1,2,3,4 与projectsData匹配
                    }
                });
                if (projectId && projectsData[projectId]) {
                    modalTitle.innerText = projectsData[projectId].title;
                    modalBody.innerHTML = projectsData[projectId].content;
                } else {
                    // fallback
                    modalTitle.innerText = '科研项目详情';
                    modalBody.innerHTML = '<p>更详细的研究介绍、数据、负责人以及发表信息会展示在这里。 (模拟内容)</p>';
                }
                // 显示浮层
                overlay.style.display = 'flex';
            });
        });

        // 关闭弹窗 (点击×或者背景)
        document.getElementById('closeDetailBtn').addEventListener('click', function() {
            overlay.style.display = 'none';
        });
        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) {
                overlay.style.display = 'none';
            }
        });

        // 可选：按ESC关闭
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && overlay.style.display === 'flex') {
                overlay.style.display = 'none';
            }
        });

        // 锚点平滑滚动
        document.querySelectorAll('.nav-item').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const targetId = this.getAttribute('href'); // #research ...
                if(targetId && targetId !== '#') {
                    e.preventDefault();
                    const targetEl = document.querySelector(targetId);
                    if(targetEl) {
                        targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                }
            });
        });
    })();
</script>
